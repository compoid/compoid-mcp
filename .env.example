# Example environment configuration for COMPOID MCP Server

# Sort order
SORT_ORDER=bestmatch

# Request timeout in seconds (default: 30.0)
COMPOID_TIMEOUT=30.0

# Maximum concurrent requests (default: 10)
COMPOID_MAX_CONCURRENT=10

# Default page size for results (default: 25)
COMPOID_DEFAULT_PAGE_SIZE=25

# Maximum page size for results (default: 200)
COMPOID_MAX_PAGE_SIZE=200

# Daily request limit (default: 100000)
COMPOID_DAILY_LIMIT=100000

# Logging level (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# Log API requests for debugging (true/false)
LOG_API_REQUESTS=false

# Upload server URL for Compoid_upload_file tool
COMPOID_UPLOAD_URL=https://mcps.compoid.com/upload
